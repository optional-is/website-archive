});

function onSauceChange() {
  const atLeastOneChecked = Array.from(sauce_checkboxes).some(cb => cb.checked);
  if (!atLeastOneChecked){
    document.getElementById('hb_sauce_1').checked = 'checked';
  }
  do_hb_calculation()
}

sauce_checkboxes.forEach(cb => {
